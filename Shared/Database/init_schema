CREATE DATABASE VerdantValor;

USE VerdantValor;

-- MySQL의 기본 user 테이블과의 충돌을 방지하기 위해 gameUser로 명명
DROP TABLE gameUser;
CREATE TABLE gameUser (
	userId		BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
	nickname	VARCHAR(20)     NOT NULL,
	email		VARCHAR(50)		NOT NULL,
	pw			CHAR(128)		NOT NULL,
	deviceId	VARCHAR(255)    NULL,
	gold		BIGINT UNSIGNED NOT NULL,
	exp		    BIGINT UNSIGNED NOT NULL,
	createdAt	DATETIME(6)     NOT NULL,
	updatedAt	DATETIME(6)     NOT NULL,

	PRIMARY KEY (userId),
	UNIQUE KEY unique_gameUser_email (email)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

DROP TABLE purchase;
CREATE TABLE purchase (
	id	BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
	storeId     INT             NOT NULL,
	state       INT             NOT NULL,
	userId      BIGINT UNSIGNED NOT NULL,
	createdAt	DATETIME(6)     NOT NULL,
	updatedAt	DATETIME(6)     NOT NULL,
	completedAt	DATETIME(6)     NULL,

	PRIMARY KEY (id),
	UNIQUE KEY unique_purchase_userId_storeId (userId, storeId)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

DROP TABLE inventory;
CREATE TABLE inventory (
	id	        BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
	itemId      INT             NOT NULL,
	state       INT             NOT NULL,
	userId      BIGINT UNSIGNED NOT NULL,
	createdAt	DATETIME(6)     NOT NULL,
	updatedAt	DATETIME(6)     NOT NULL,
	ExpiredAt	DATETIME(6)     NULL,
	UsedAt	    DATETIME(6)     NULL,

	PRIMARY KEY (id),
	UNIQUE KEY unique_inventory_userId_itemId (userId, itemId)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

